# PostgreSQL (Neon, Vercel Postgres, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# NextAuth v5 reads AUTH_SECRET; older docs use NEXTAUTH_SECRET (either works in this app).
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Production: your site URL (helps NextAuth callbacks)
# AUTH_URL="https://your-project.vercel.app"

# Vercel: enable Blob in the project dashboard, then add this token for image uploads.
# Local dev without this token uses public/uploads on disk.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Optional: password for prisma/seed default user "admin"
# SEED_PASSWORD="your-secure-password"

# --- Login works locally but not on Vercel? ---
# Production uses Neon: the `admin` user must exist IN THAT DATABASE.
# 1) Vercel → pocketgram → Settings → Environment Variables → copy DATABASE_URL (Production).
# 2) In this project folder, set DATABASE_URL in .env to that exact value (temporarily).
# 3) Run: npx prisma db seed
#    (Password is SEED_PASSWORD if set, otherwise "changeme".)
# 4) Restore your local .env if needed.
#
# Or: install Vercel CLI, run `vercel link`, then `vercel env pull .env.vercel.local`,
# then: npx dotenv-cli -e .env.vercel.local -- npx prisma db seed
# (npm i -D dotenv-cli if you use that form.)
